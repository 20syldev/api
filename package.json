{
    "version": "3.4.0",
    "name": "@20syldev/api",
    "description": "Node.js API with multiple features. Check the documentation at https://docs.sylvain.sh",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "start": "node app.js",
        "dev": "nodemon app.js",
        "build": "npm install && node app.js",
        "lint": "prettier --write .",
        "upgrade:minor": "npm upgrade",
        "upgrade:major": "npx npm-check-updates -u && npm install",
        "upgrade:build": "npm upgrade && npm install && node app.js"
    },
    "exports": {
        "./v1": "./modules/v1.js",
        "./v2": "./modules/v2.js",
        "./v3": "./modules/v3.js"
    },
    "dependencies": {
        "canvas": "^3.1.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^5.1.0",
        "ical.js": "^2.1.0",
        "node-fetch": "^3.3.2",
        "qrcode": "^1.5.4",
        "random": "^5.3.0",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.10",
        "npm-check-updates": "^18.0.1",
        "prettier": "^3.5.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/20syldev/api.git"
    },
    "keywords": [
        "api",
        "express",
        "utility",
        "math"
    ],
    "author": "Sylvain L.",
    "license": "BSD 3-Clause",
    "bugs": {
        "url": "https://github.com/20syldev/api/issues"
    },
    "homepage": "https://api.sylvain.sh"
}
